# =============================================================================
# pcloudcc Docker - Environment Configuration
# Copy this file to .env and fill in your values:  cp .env.sample .env
# =============================================================================

# --- Required ---
# pCloud account email address
PCLOUD_USER=your@email.com

# --- Authentication (optional) ---
# Account password — only needed for automatic first-time login. Once
# /root/.pcloud/data.db has been created, this can be removed again.
#PCLOUD_PASSWORD=

# Alternative: path to a file containing the account password (Docker secret).
#PCLOUD_PASSWORD_FILE=

# TOTP shared secret (base32, as shown by your authenticator when you set
# up 2FA — usually labeled "secret key" or "manual entry key"). If set,
# fresh 6-digit codes are generated automatically with oathtool, so the
# first-time login no longer depends on a manually entered one-shot code.
#PCLOUD_TOTP_SECRET=

# Alternative: path to a file containing the TOTP secret (Docker secret).
#PCLOUD_TOTP_SECRET_FILE=

# Single-use 2FA code (alternative to PCLOUD_TOTP_SECRET). Only useful for
# a single first-time login — codes expire after ~30 seconds, so prefer
# PCLOUD_TOTP_SECRET for unattended setups.
#PCLOUD_2FA=

# Crypto folder password (leave empty to skip crypto unlock)
#PCLOUD_CRYPT=

# Alternative: path to a file containing the crypto password.
# Use this instead of PCLOUD_CRYPT to avoid exposing the password in the
# environment (e.g. with Docker secrets: /run/secrets/pcloud_crypt).
#PCLOUD_CRYPT_FILE=

# --- Mount settings (optional) ---
# Internal mount point inside the container (default: /pcloud_internal)
#PCLOUD_MOUNT=/pcloud_internal

# --- Bindfs uid/gid remapping (optional) ---
# Set to 1 to enable bindfs overlay for uid/gid remapping
#ENABLE_BINDFS=1

# Target mount point for bindfs (default: /pcloud)
#BINDFS_TARGET=/pcloud

# Map files to this UID/GID on the host (default: 1000)
#UID=1000
#GID=1000

# Owner name/group for the internal mount (default: nobody/users)
#USER=nobody
#GROUP=users

# --- Timeouts (optional) ---
# Seconds to wait for a mount to become ready (default: 60).
# Raise this on slow ARM devices or high-latency links if startup logs
# show a mount-timeout warning.
#MOUNT_TIMEOUT=60
