# =============================================================================
# pcloudcc Docker - Environment Configuration
# Copy this file to .env and fill in your values:  cp .env.sample .env
# =============================================================================

# --- Required ---
# pCloud account email address
PCLOUD_USER=your@email.com

# --- Authentication (optional) ---
# 2FA code (only needed for first-time login)
#PCLOUD_2FA=

# Crypto folder password (leave empty to skip crypto unlock)
#PCLOUD_CRYPT=

# --- Mount settings (optional) ---
# Internal mount point inside the container (default: /pcloud_internal)
#PCLOUD_MOUNT=/pcloud_internal

# --- Bindfs uid/gid remapping (optional) ---
# Set to 1 to enable bindfs overlay for uid/gid remapping
#ENABLE_BINDFS=1

# Target mount point for bindfs (default: /pcloud)
#BINDFS_TARGET=/pcloud

# Map files to this UID/GID on the host (default: 1000)
#UID=1000
#GID=1000

# Owner name/group for the internal mount (default: nobody/users)
#USER=nobody
#GROUP=users

# --- Timeouts (optional) ---
# Seconds to wait for a mount to become ready (default: 120)
#MOUNT_TIMEOUT=120
